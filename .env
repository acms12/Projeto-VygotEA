# Configurações da API
HOST=0.0.0.0
PORT=8000
DEBUG=true
ENVIRONMENT=development
VERSION=2.0.0

# Configurações de Segurança
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Configurações de Log
LOG_LEVEL=INFO
LOG_FORMAT=json

# Configurações de Banco de Dados
DATABASE_TYPE=sqlite
DATABASE_URL=sqlite:///./vygotea.db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=vygotea
POSTGRES_USER=vygotea_user
POSTGRES_PASSWORD=vygotea_password
MONGODB_URL=mongodb://localhost:27017/vygotea
ELASTICSEARCH_URL=http://localhost:9200

# Configurações de Cache
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600

# Configurações de ML/AI
ML_MODEL_TYPE=traditional
DEEP_LEARNING_AVAILABLE=false
OPENAI_API_KEY=your-openai-api-key-here
MODEL_PATH=./models
TRAINING_DATA_PATH=./data/training

# Configurações RAG
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
VECTOR_DIMENSION=384
SIMILARITY_THRESHOLD=0.7
MAX_RESULTS=10

# Configurações de Gamificação
XP_MULTIPLIER=1.0
STREAK_BONUS=0.1
DIFFICULTY_BONUS=0.2
BADGE_XP_REWARD=100
LEVEL_UP_XP=1000

# Configurações ZDP
ZDP_ZONE_WIDTH=0.2
ZDP_CONFIDENCE_THRESHOLD=0.7
ZDP_ADAPTIVE_FACTOR=0.1
ZDP_HISTORY_WEIGHT=0.3

# Configurações de Intervenção
INTERVENTION_URGENCY_THRESHOLD=0.8
INTERVENTION_PERSONALIZATION_LEVEL=0.7
INTERVENTION_CONTEXT_WINDOW=5

# Configurações de Circuit Breaker
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=60
CIRCUIT_BREAKER_HALF_OPEN_MAX_CALLS=3

# Configurações de Métricas
ENABLE_METRICS=true
METRICS_PORT=9090

# Configurações de Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Configurações de Filas
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Configurações de Monitoramento
PROMETHEUS_ENABLED=true
HEALTH_CHECK_INTERVAL=30

# Configurações de Desenvolvimento
RELOAD=true
WORKERS=1